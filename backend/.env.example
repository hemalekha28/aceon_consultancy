# Backend Environment Variables Template
# IMPORTANT: Copy this to .env and fill with YOUR actual values
# NEVER commit .env file to git!

PORT=5000
MONGODB_URI=mongodb://localhost:27017/mattress_aceon
JWT_SECRET=your-secret-key-here-min-64-chars
NODE_ENV=development

# Razorpay Payment Gateway (Test credentials)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Email Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-not-gmail-password
MAIL_FROM=<noreply@yourdomain.com>

# Firebase (Optional - only if using backend admin SDK)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
